rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Anyone can read reports to render them on the map / explore dashboards
      allow read: if true;
      
      // Anyone can submit new civic reports
      allow create: if true;
      
      // Anyone can update reports (e.g., adding witness signatures, changing status, AI Watchdog auto-escalation)
      allow update: if true;
      
      // Deleting is disabled for civic trace integrity
      allow delete: if false;
    }
  }
}
